database:
  url: "sqlite:///./pelis_feed.db"
  # Alternative: "mysql+pymysql://user:pass@localhost/pelis_feed"

feed:
  url: "https://yts.mx/rss"

series_feed:
  url: "https://eztv.re/ezrss.xml"
  # Optional — new series whose title matches any pattern here are created
  # directly in "Following" instead of "Inbox". Checked once, only when a
  # series is first ingested; never re-applied afterward or to series the
  # user has since set manually.
  follow_filters:
    - name: "example"
      pattern: "(Breaking Bad|Better Call Saul)"
    - name: "Silo"
      pattern: "Silo"
    - name: "Pluribus"
      pattern: "Pluribus"
    - name: "Foundation"
      pattern: "Foundation"
    - name: "Strange New Worlds"
      pattern: "Strange New Worlds"
    - name: "Bad Monkey"
      pattern: "Bad Monkey"

alerting:
  smtp_host: "localhost"
  smtp_port: 25
  from_address: "pelis-feed@localhost"
  to_address: "user@localhost"
  downtime_threshold_hours: 24

enrichment:
  source: "omdb"
  api_key: ""
  timeout_seconds: 10

filtering:
  default:
    min_imdb: 6.0
    min_rt_expert: 60
    min_rt_audience: 50
  genres:
    action:
      min_imdb: 5.5
    romantic_comedy:
      min_imdb: 5.0
    documentary:
      min_imdb: 7.0
      min_rt_expert: 80
  older_movies:
    min_imdb: 7.5
    min_rt_expert: 75
    year_threshold: 6

genre_priority:
  - action
  - romantic_comedy
  - thriller
  - sci-fi
  - drama
  - horror
  - comedy
  - documentary

webapp:
  # Only local access
  host: "127.0.0.1"
  # External access is permitted
  #host: "0.0.0.0"
  port: 8080

# News feeds — remove this section if you don't need news ingestion.
# Each feed has a type: unfiltered | filtered
# Each feed also has an optional tag — groups feeds into tabs in the News UI
# (defaults to "General" if omitted). Order tabs left-to-right via news_tag_priority
# below; any tag used here but not listed there still gets a tab, appended after.
news_tag_priority:
  - tech
  - world
  - science
  - data
  - security
  - misc

news_feeds:
  - name: "Tech News"
    url: "https://www.scmp.com/rss/320663/feed"
    type: unfiltered
    tag: tech

  - name: "International News El Mundo"
    url: "https://e00-elmundo.uecdn.es/elmundo/rss/internacional.xml"
    type: unfiltered
    tag: world

  - name: "International News El Pais"
    url: "https://feeds.elpais.com/mrss-s/pages/ep/site/elpais.com/section/internacional/portada"
    type: unfiltered
    tag: world

  - name: "Torrent Freak"
    url: "http://feeds.feedburner.com/Torrentfreak"
    type: unfiltered
    tag: tech

  - name: "Visual Capitalist"
    url: "https://feeds.feedburner.com/visualcapitalist"
    type: unfiltered
    tag: data

  - name: "IEEE Spectrum"
    url: "https://spectrum.ieee.org/feeds/feed.rss"
    type: unfiltered
    tag: tech

  - name: "Eureka"
    url: "http://feeds.feedburner.com/naukas/danielmarin?format=xml"
    type: unfiltered
    tag: science

  - name: "Linux Gizmos"
    url: "http://linuxgizmos.com/feed/"
    type: unfiltered
    tag: tech

  - name: "IEEE Spectrum Robotics"
    url: "http://feeds.feedburner.com/IeeeSpectrumRobotics"
    type: unfiltered
    tag: tech

  - name: "The Conversation"
    url: "https://theconversation.com/us/articles.atom"
    type: unfiltered
    tag: world

  - name: "South China Morning Post"
    url: "https://www.scmp.com/rss/320663/feed"
    type: unfiltered
    tag: world

  - name: "Our World in Data"
    url: "https://ourworldindata.org/feed"
    type: unfiltered
    tag: data

  - name: "Web3 is going great"
    url: "https://web3isgoinggreat.com/feed.xml"
    type: unfiltered
    tag: tech

  - name: "Bitcoin Magazine"
    url: "https://bitcoinmagazine.com/.rss/full/"
    type: unfiltered
    tag: tech

  - name: "Beto Valdez"
    url: "http://betovaldez.com.ar/feed/"
    type: unfiltered
    tag: misc

  - name: "Linode Blog"
    url: "https://blog.linode.com/feed/"
    type: unfiltered
    tag: tech

  - name: "Debian News"
    url: "http://www.debian.org/News/news"
    type: unfiltered
    tag: tech

  - name: "Security"
    url: "https://example.com/security/feed"
    type: filtered
    tag: security
    filters:
      - name: "vulnerabilities"
        pattern: "(CVE|vulnerability|exploit|breach)"
      - name: "tooling"
        pattern: "(release|update|patch) v?[0-9]"

# Design feeds — remove this section if you don't need design article ingestion.
# Images are extracted best-effort: media:content → enclosure → first <img> in description.
design_feeds:
  - name: "Designboom"
    url: "https://www.designboom.com/feed/"
