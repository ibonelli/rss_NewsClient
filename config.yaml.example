database:
  url: "sqlite:///./pelis_feed.db"
  # Alternative: "mysql+pymysql://user:pass@localhost/pelis_feed"

feed:
  url: "https://yts.mx/rss"

series_feed:
  url: "https://eztv.re/ezrss.xml"
  # Optional — new series whose title matches any pattern here are created
  # directly in "Following" instead of "Inbox". Checked once, only when a
  # series is first ingested; never re-applied afterward or to series the
  # user has since set manually.
  follow_filters:
    - name: "example"
      pattern: "(Breaking Bad|Better Call Saul)"
    - name: "Silo"
      pattern: "Silo"
    - name: "Pluribus"
      pattern: "Pluribus"
    - name: "Foundation"
      pattern: "Foundation"
    - name: "Strange New Worlds"
      pattern: "Strange New Worlds"
    - name: "Bad Monkey"
      pattern: "Bad Monkey"

alerting:
  smtp_host: "localhost"
  smtp_port: 25
  from_address: "pelis-feed@localhost"
  to_address: "user@localhost"
  downtime_threshold_hours: 24

enrichment:
  source: "omdb"
  api_key: ""
  timeout_seconds: 10

filtering:
  default:
    min_imdb: 6.0
    min_rt_expert: 60
    min_rt_audience: 50
  genres:
    action:
      min_imdb: 5.5
    romantic_comedy:
      min_imdb: 5.0
    documentary:
      min_imdb: 7.0
      min_rt_expert: 80
  older_movies:
    min_imdb: 7.5
    min_rt_expert: 75
    year_threshold: 6

genre_priority:
  - action
  - romantic_comedy
  - thriller
  - sci-fi
  - drama
  - horror
  - comedy
  - documentary

webapp:
  # Only local access
  host: "127.0.0.1"
  # External access is permitted
  #host: "0.0.0.0"
  port: 8080

# News feeds — remove this section if you don't need news ingestion.
# Each feed has a type: unfiltered | filtered
news_feeds:
  - name: "Tech News"
    url: "https://www.scmp.com/rss/320663/feed"
    type: unfiltered

  - name: "Internacional News El Mundo"
    url: "https://e00-elmundo.uecdn.es/elmundo/rss/internacional.xml"
    type: unfiltered

  - name: "Internacional News El Pais"
    url: "http://ep00.epimg.net/rss/internacional/portada.xml"
    type: unfiltered

  - name: "Torrent Freak"
    url: "http://feeds.feedburner.com/Torrentfreak"
    type: unfiltered

  - name: "Visual Capitalist"
    url: "https://feeds.feedburner.com/visualcapitalist"
    type: unfiltered

  - name: "IEEE Spectrum"
    url: "https://spectrum.ieee.org/feeds/feed.rss"
    type: unfiltered

  - name: "Security"
    url: "https://example.com/security/feed"
    type: filtered
    filters:
      - name: "vulnerabilities"
        pattern: "(CVE|vulnerability|exploit|breach)"
      - name: "tooling"
        pattern: "(release|update|patch) v?[0-9]"

# Design feeds — remove this section if you don't need design article ingestion.
# Images are extracted best-effort: media:content → enclosure → first <img> in description.
design_feeds:
  - name: "Designboom"
    url: "https://www.designboom.com/feed/"
